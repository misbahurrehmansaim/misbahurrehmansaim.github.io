<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FlyBee Travels — Growth & Marketing Strategy 2026</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --gold: #C9A84C;
    --gold-light: #E8C97A;
    --gold-pale: #FAF3E0;
    --navy: #0D1B2A;
    --navy-mid: #1A2E44;
    --navy-soft: #243D55;
    --cream: #F9F5EE;
    --cream-dark: #EFE9DC;
    --text-dark: #1A1A1A;
    --text-mid: #4A4A4A;
    --text-muted: #7A7A7A;
    --green: #1E6B4F;
    --green-pale: #E8F5EF;
    --red-pale: #FDE8E8;
    --red: #C0392B;
    --border: #E0D8CC;
    --radius: 12px;
    --radius-sm: 6px;
  }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--cream);
    color: var(--text-dark);
    line-height: 1.7;
    font-size: 15px;
  }

  /* ── COVER PAGE ── */
  .cover {
    background: var(--navy);
    color: white;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 80px 60px;
    position: relative;
    overflow: hidden;
  }
  .cover::before {
    content: '';
    position: absolute;
    top: -100px; right: -100px;
    width: 500px; height: 500px;
    border-radius: 50%;
    border: 1px solid rgba(201,168,76,0.15);
  }
  .cover::after {
    content: '';
    position: absolute;
    bottom: -80px; left: -80px;
    width: 400px; height: 400px;
    border-radius: 50%;
    border: 1px solid rgba(201,168,76,0.1);
  }
  .cover-label {
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 24px;
  }
  .cover h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(42px, 6vw, 72px);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 8px;
  }
  .cover h1 span { color: var(--gold); }
  .cover-sub {
    font-size: 18px;
    color: rgba(255,255,255,0.6);
    margin-bottom: 48px;
    font-weight: 300;
  }
  .cover-pills {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 60px;
  }
  .cover-pill {
    padding: 8px 20px;
    border: 1px solid rgba(201,168,76,0.4);
    border-radius: 40px;
    font-size: 13px;
    color: rgba(255,255,255,0.75);
  }
  .cover-pill.active {
    background: var(--gold);
    border-color: var(--gold);
    color: var(--navy);
    font-weight: 500;
  }
  .cover-meta {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    max-width: 600px;
  }
  .cover-meta-item label {
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
    display: block;
    margin-bottom: 4px;
  }
  .cover-meta-item p {
    font-size: 14px;
    color: rgba(255,255,255,0.85);
    font-weight: 500;
  }

  /* ── LAYOUT ── */
  .page {
    max-width: 900px;
    margin: 0 auto;
    padding: 60px 40px;
  }
  .page + .page { border-top: 1px solid var(--border); }

  /* ── SECTION HEADERS ── */
  .section-eyebrow {
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 10px;
    font-weight: 500;
  }
  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(26px, 3.5vw, 36px);
    font-weight: 700;
    color: var(--navy);
    line-height: 1.2;
    margin-bottom: 12px;
  }
  .section-intro {
    font-size: 16px;
    color: var(--text-mid);
    margin-bottom: 40px;
    max-width: 640px;
  }

  /* ── DIVIDER ── */
  .gold-line {
    width: 48px; height: 2px;
    background: var(--gold);
    margin-bottom: 20px;
  }

  /* ── ANALYSIS CARDS ── */
  .analysis-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 32px;
  }
  .analysis-card {
    background: white;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 24px;
  }
  .analysis-card.good { border-left: 3px solid var(--green); }
  .analysis-card.bad { border-left: 3px solid var(--red); }
  .analysis-card h4 {
    font-size: 13px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 16px;
  }
  .analysis-card.good h4 { color: var(--green); }
  .analysis-card.bad h4 { color: var(--red); }
  .analysis-item {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    margin-bottom: 12px;
    font-size: 14px;
    color: var(--text-mid);
    line-height: 1.5;
  }
  .dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    margin-top: 6px;
    flex-shrink: 0;
  }
  .dot.green { background: var(--green); }
  .dot.red { background: var(--red); }

  /* ── GOAL BANNERS ── */
  .goal-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 32px;
  }
  .goal-card {
    border-radius: var(--radius);
    padding: 28px;
    position: relative;
    overflow: hidden;
  }
  .goal-card.seo { background: var(--navy); color: white; }
  .goal-card.social { background: var(--gold-pale); color: var(--navy); border: 1px solid var(--gold-light); }
  .goal-card .goal-icon {
    font-size: 28px;
    margin-bottom: 16px;
    display: block;
  }
  .goal-card h3 {
    font-family: 'Playfair Display', serif;
    font-size: 20px;
    margin-bottom: 8px;
  }
  .goal-card.seo h3 { color: var(--gold-light); }
  .goal-card.social h3 { color: var(--navy); }
  .goal-card p {
    font-size: 14px;
    opacity: 0.8;
    line-height: 1.6;
  }
  .goal-badge {
    display: inline-block;
    margin-top: 16px;
    padding: 5px 14px;
    border-radius: 40px;
    font-size: 12px;
    font-weight: 500;
  }
  .goal-card.seo .goal-badge {
    background: rgba(201,168,76,0.2);
    color: var(--gold-light);
  }
  .goal-card.social .goal-badge {
    background: var(--navy);
    color: var(--gold-light);
  }

  /* ── PHASE TIMELINE ── */
  .phase-block {
    background: white;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    margin-bottom: 20px;
    overflow: hidden;
  }
  .phase-header {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 20px 28px;
    cursor: pointer;
    background: white;
    border-bottom: 1px solid var(--border);
  }
  .phase-num {
    width: 40px; height: 40px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-weight: 500;
    font-size: 14px;
    flex-shrink: 0;
  }
  .phase-num.p1 { background: var(--navy); color: var(--gold); }
  .phase-num.p2 { background: var(--gold); color: var(--navy); }
  .phase-num.p3 { background: var(--green); color: white; }
  .phase-num.p4 { background: var(--navy-mid); color: var(--gold-light); }
  .phase-title-wrap h3 {
    font-size: 16px;
    font-weight: 500;
    color: var(--navy);
  }
  .phase-title-wrap span {
    font-size: 12px;
    color: var(--text-muted);
  }
  .phase-body {
    padding: 24px 28px;
  }
  .phase-cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }
  .phase-col-title {
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 14px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border);
  }
  .phase-col-title.seo { color: var(--navy); }
  .phase-col-title.social { color: var(--gold); }
  .task-item {
    display: flex;
    gap: 10px;
    margin-bottom: 10px;
    font-size: 14px;
    color: var(--text-mid);
    line-height: 1.5;
  }
  .task-num {
    background: var(--cream);
    border: 1px solid var(--border);
    border-radius: 4px;
    width: 20px; height: 20px;
    display: flex; align-items: center; justify-content: center;
    font-size: 11px;
    color: var(--text-muted);
    flex-shrink: 0;
    margin-top: 1px;
  }

  /* ── KEYWORD TABLE ── */
  .kw-section {
    margin-bottom: 32px;
  }
  .kw-category {
    font-size: 13px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--navy);
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .kw-category::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }
  .kw-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 10px;
    margin-bottom: 24px;
  }
  .kw-pill {
    background: white;
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 10px 14px;
    font-size: 13px;
  }
  .kw-pill .kw-text { color: var(--text-dark); font-weight: 500; margin-bottom: 2px; }
  .kw-pill .kw-meta { color: var(--text-muted); font-size: 11px; }
  .kw-pill.priority { border-color: var(--gold); border-left: 3px solid var(--gold); }

  /* ── CONTENT PLAN ── */
  .content-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 32px;
  }
  .content-card {
    background: white;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 20px;
  }
  .content-card-type {
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 10px;
    font-weight: 500;
  }
  .content-card h4 { font-size: 14px; font-weight: 500; color: var(--navy); margin-bottom: 8px; }
  .content-card p { font-size: 13px; color: var(--text-muted); line-height: 1.5; }

  /* ── SOCIAL STRATEGY ── */
  .social-platform {
    display: grid;
    grid-template-columns: 60px 1fr;
    gap: 20px;
    background: white;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 24px;
    margin-bottom: 16px;
    align-items: start;
  }
  .platform-icon {
    width: 52px; height: 52px;
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    font-size: 22px;
    font-weight: 700;
  }
  .ig { background: #FFEAF0; color: #C13584; }
  .fb { background: #E8F0FE; color: #1877F2; }
  .yt { background: #FDECEA; color: #FF0000; }
  .wa { background: #E8F5E9; color: #25D366; }
  .platform-details h4 { font-size: 15px; font-weight: 500; color: var(--navy); margin-bottom: 6px; }
  .platform-details p { font-size: 13px; color: var(--text-mid); margin-bottom: 12px; line-height: 1.5; }
  .post-types { display: flex; gap: 8px; flex-wrap: wrap; }
  .post-type-tag {
    padding: 4px 12px;
    background: var(--cream-dark);
    border-radius: 40px;
    font-size: 12px;
    color: var(--text-mid);
  }

  /* ── METRICS TABLE ── */
  .metrics-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 32px;
    background: white;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
  }
  .metrics-table th {
    background: var(--navy);
    color: var(--gold-light);
    padding: 14px 20px;
    text-align: left;
    font-size: 12px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    font-weight: 500;
  }
  .metrics-table td {
    padding: 14px 20px;
    font-size: 14px;
    border-bottom: 1px solid var(--border);
    color: var(--text-mid);
  }
  .metrics-table tr:last-child td { border-bottom: none; }
  .metrics-table tr:nth-child(even) td { background: var(--cream); }
  .metric-name { font-weight: 500; color: var(--text-dark) !important; }
  .metric-target { color: var(--green) !important; font-weight: 500; }

  /* ── PITCH SECTION ── */
  .pitch-box {
    background: var(--navy);
    border-radius: var(--radius);
    padding: 40px;
    color: white;
    margin-bottom: 24px;
  }
  .pitch-box h3 {
    font-family: 'Playfair Display', serif;
    font-size: 24px;
    color: var(--gold-light);
    margin-bottom: 16px;
  }
  .pitch-box p { font-size: 15px; opacity: 0.8; line-height: 1.7; margin-bottom: 20px; }
  .service-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-top: 24px;
  }
  .service-card {
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(201,168,76,0.2);
    border-radius: var(--radius-sm);
    padding: 20px;
  }
  .service-card h5 {
    color: var(--gold-light);
    font-size: 14px;
    font-weight: 500;
    margin-bottom: 8px;
  }
  .service-card p {
    font-size: 12px;
    opacity: 0.65;
    margin-bottom: 0;
    line-height: 1.5;
  }
  .service-price {
    margin-top: 12px;
    font-size: 11px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--gold);
  }

  /* ── ROI STRIP ── */
  .roi-strip {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    margin-bottom: 32px;
  }
  .roi-item {
    background: white;
    padding: 24px 20px;
    text-align: center;
  }
  .roi-item .roi-num {
    font-family: 'Playfair Display', serif;
    font-size: 32px;
    color: var(--navy);
    display: block;
    line-height: 1;
    margin-bottom: 6px;
  }
  .roi-item .roi-label { font-size: 12px; color: var(--text-muted); }

  /* ── FOOTER ── */
  .doc-footer {
    background: var(--navy);
    color: rgba(255,255,255,0.5);
    text-align: center;
    padding: 32px 40px;
    font-size: 13px;
  }
  .doc-footer strong { color: var(--gold); }

  /* ── PRINT / PAGE BREAK ── */
  @media print {
    .cover { min-height: auto; padding: 60px 40px; page-break-after: always; }
    .page { padding: 40px; }
    .phase-block { break-inside: avoid; }
  }

  /* ── UTILITY ── */
  .tag-row { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 12px; }
  .tag {
    padding: 5px 14px;
    border-radius: 40px;
    font-size: 12px;
    font-weight: 500;
  }
  .tag-navy { background: var(--navy); color: var(--gold-light); }
  .tag-gold { background: var(--gold-pale); color: var(--navy); border: 1px solid var(--gold-light); }
  .tag-green { background: var(--green-pale); color: var(--green); }
  .callout {
    background: var(--gold-pale);
    border-left: 3px solid var(--gold);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    padding: 16px 20px;
    font-size: 14px;
    color: var(--text-mid);
    margin: 20px 0;
    line-height: 1.6;
  }
  .callout strong { color: var(--navy); }
  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
  .three-col { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px; }
  hr.section-rule { border: none; border-top: 1px solid var(--border); margin: 48px 0; }
</style>
</head>
